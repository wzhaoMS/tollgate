# Local Copilot bridge (chat completions endpoint)
BRIDGE_BASE_URL=http://localhost:4141/v1
BRIDGE_API_KEY=dummy
BRIDGE_MODEL=claude-opus-4.7-1m-internal

# SEC EDGAR REQUIRES a real user-agent with contact email per Fair Access policy
# https://www.sec.gov/os/accessing-edgar-data
EDGAR_USER_AGENT=serenity-killer-playbook wzhaoMS+edgar@users.noreply.github.com

# Telegram digest (optional, leave blank to print to stdout only)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# DB
DB_PATH=data/playbook.db

# Polite rate-limit (EDGAR allows up to 10 req/sec; we use 5)
EDGAR_RPS=5
